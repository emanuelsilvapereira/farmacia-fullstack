generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // Mudamos para MySQL
}

// --- TABELAS DO SISTEMA ---

model Usuario {
  id       Int      @id @default(autoincrement())
  nome     String
  email    String   @unique
  senha    String // Guardaremos a senha criptografada aqui
  role     String   @default("ATENDENTE") // Pode ser: ADMIN, FARMACEUTICO ou ATENDENTE
  criadoEm DateTime @default(now())
}

model Produto {
  id            Int    @id @default(autoincrement())
  nome          String @unique
  fabricante    String
  medida        String
  categoria     String // Anestésico, Analgésico, etc
  estoqueMinimo Int    @default(10)

  // Relacionamento: 1 Produto tem Vários Lotes
  lotes Lote[]

  movimentacoes Movimentacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lote {
  id         Int      @id @default(autoincrement())
  numeroLote String
  validade   DateTime
  quantidade Int      @default(0)

  // Chave estrangeira ligando ao Produto
  produtoId Int
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
}

model Movimentacao {
  id         Int      @id @default(autoincrement())
  tipo       String // Vai gravar se foi "ENTRADA" ou "SAIDA"
  quantidade Int
  data       DateTime @default(now())

  // Relacionamento com o Produto
  produtoId Int
  produto   Produto @relation(fields: [produtoId], references: [id])
  medicoId  Int? // <-- Tem que ter o ?
  medico    Medico? @relation(fields: [medicoId], references: [id]) // <-- Tem que ter o ?
  ubsId     Int? // <-- Tem que ter o ?
  ubs       Ubs?    @relation(fields: [ubsId], references: [id]) // <-- Tem que ter o ?
}

model Ubs {
  id            Int            @id @default(autoincrement())
  nome          String         @unique
  bairro        String
  cep           String
  rua           String
  medicos       Medico[] // Uma UBS tem vários médicos
  createdAt     DateTime       @default(now())
  movimentacoes Movimentacao[]
}

model Medico {
  id            Int            @id @default(autoincrement())
  nome          String
  crm           String         @unique
  ubs           Ubs            @relation(fields: [ubsId], references: [id])
  ubsId         Int
  createdAt     DateTime       @default(now())
  movimentacoes Movimentacao[]
}
